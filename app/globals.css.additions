/* UI/UX v2 additions */
.nav-link{position:relative;padding:6px 2px}
.nav-link::after{content:"";position:absolute;left:0;bottom:0;width:0%;height:2px;background:#005C07;transition:width .18s ease}
.nav-link:hover::after{width:100%}
.sticky-cta{position:sticky;bottom:12px;margin-top:24px;padding:10px 14px;border-radius:16px;background:rgba(240,255,243,.9);border:1px solid rgba(0,0,0,.06);backdrop-filter:blur(6px)}
.container{width:100%;max-width:1100px;margin-left:auto;margin-right:auto;padding-left:1rem;padding-right:1rem}
